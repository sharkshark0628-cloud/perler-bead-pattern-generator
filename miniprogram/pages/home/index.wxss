.home-page {
  min-height: 100vh;
  padding-bottom: 104px;
  background: var(--color-ivory);
}

.home-page__content {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  padding: var(--space-6) var(--page-padding-x) var(--space-8);
}

.brand-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 48px;
}

.brand-row__name {
  color: var(--color-ink);
  font-size: var(--font-size-page-title);
  font-weight: var(--font-weight-bold);
  line-height: var(--line-height-title);
}

.brand-row__more {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  color: var(--color-ink);
  border-radius: var(--radius-full);
  transition: transform var(--motion-fast) var(--motion-ease),
    background-color var(--motion-fast) var(--motion-ease);
}

.brand-row__more--pressed {
  background: var(--color-cream-pink-soft);
  transform: scale(0.98);
}

.brand-row__more-icon {
  font-size: 20px;
  font-weight: var(--font-weight-semibold);
  line-height: 1;
}

.hero-card {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  min-height: 156px;
}

.hero-card__copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.hero-card__eyebrow {
  margin-bottom: var(--space-3);
  color: var(--color-ink-soft);
  font-size: var(--font-size-body);
  font-weight: var(--font-weight-semibold);
  line-height: var(--line-height-body);
}

.hero-card__title {
  color: var(--color-ink);
  font-size: var(--font-size-display);
  font-weight: var(--font-weight-bold);
  line-height: var(--line-height-display);
}

.hero-card__character {
  display: flex;
  flex: 0 0 25%;
  align-items: flex-end;
  justify-content: flex-end;
  min-width: 72px;
}

.brand-character {
  position: relative;
  width: 72px;
  height: 84px;
}

.brand-character__head {
  position: absolute;
  top: 0;
  right: 4px;
  display: flex;
  gap: var(--space-2);
  align-items: center;
  justify-content: center;
  width: 56px;
  height: 56px;
  background: var(--color-surface);
  border: var(--border-subtle);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-soft);
}

.brand-character__eye {
  width: 6px;
  height: 6px;
  background: var(--color-ink);
  border-radius: var(--radius-full);
}

.brand-character__body {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 64px;
  height: 40px;
  background: var(--color-oat-yellow-soft);
  border: 1px solid var(--color-line);
  border-radius: var(--radius-l);
}

.upload-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 300px;
  padding: var(--space-6) var(--space-4);
  border: var(--border-upload-dashed);
  border-radius: var(--radius-xl);
}

.upload-card__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  margin-bottom: var(--space-4);
  color: var(--color-primary-action);
  background: var(--color-cream-pink-soft);
  border-radius: var(--radius-full);
  font-size: 32px;
  font-weight: var(--font-weight-regular);
  line-height: 1;
}

.upload-card__title {
  color: var(--color-ink);
  font-size: var(--font-size-section-title);
  font-weight: var(--font-weight-semibold);
  line-height: var(--line-height-title);
}

.upload-card__meta {
  margin-top: var(--space-2);
  color: var(--color-muted);
  font-size: var(--font-size-caption);
  line-height: 1.45;
}

.quick-explanation {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-3);
  margin-top: var(--space-2);
}

.quick-explanation__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
  padding: var(--space-3) var(--space-2);
  color: var(--color-ink-soft);
}

.quick-explanation__mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  margin-bottom: var(--space-2);
  color: var(--color-ink);
  background: var(--color-surface);
  border: var(--border-subtle);
  border-radius: var(--radius-full);
  font-size: var(--font-size-micro);
  font-weight: var(--font-weight-semibold);
  line-height: 1;
}

.quick-explanation__label {
  overflow-wrap: anywhere;
  font-size: var(--font-size-caption);
  line-height: 1.35;
  text-align: center;
}

