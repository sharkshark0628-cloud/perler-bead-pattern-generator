.generation-options-page {
  min-height: 100vh;
  background: var(--color-ivory);
}

.generation-options-page__content {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  padding: var(--space-5) var(--page-padding-x) calc(var(--space-16) + var(--space-8));
}

.generation-options-page__header {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.generation-options-page__title {
  color: var(--color-ink);
  font-size: var(--font-size-page-title);
  font-weight: var(--font-weight-bold);
  line-height: var(--line-height-title);
}

.generation-options-page__subtitle {
  color: var(--color-ink-soft);
  font-size: var(--font-size-body);
  line-height: var(--line-height-body);
}

.hero-preview {
  display: flex;
  gap: var(--space-4);
  align-items: center;
  min-height: 148px;
}

.hero-preview__visual {
  flex: 0 0 116px;
}

.hero-preview__canvas {
  position: relative;
  overflow: hidden;
  aspect-ratio: 1;
  background: var(--color-ivory);
  border: var(--border-subtle);
  border-radius: var(--radius-l);
}

.hero-preview__shape {
  position: absolute;
  border: var(--border-subtle);
  border-radius: var(--radius-l);
}

.hero-preview__shape--large {
  right: -18px;
  bottom: -14px;
  width: 88px;
  height: 84px;
  background: var(--color-cream-pink-soft);
}

.hero-preview__shape--medium {
  top: var(--space-4);
  left: var(--space-4);
  width: 48px;
  height: 48px;
  background: var(--color-oat-yellow-soft);
  border-radius: var(--radius-full);
}

.hero-preview__shape--small {
  right: var(--space-4);
  top: var(--space-5);
  width: 24px;
  height: 24px;
  background: var(--color-surface);
  border-radius: var(--radius-full);
}

.hero-preview--subject .hero-preview__shape--large {
  right: var(--space-4);
  bottom: var(--space-3);
  width: 68px;
  height: 76px;
  background: var(--color-cream-pink-soft);
}

.hero-preview--subject .hero-preview__shape--medium {
  top: var(--space-3);
  left: var(--space-5);
}

.hero-preview--background .hero-preview__shape--large {
  right: var(--space-3);
  bottom: var(--space-3);
  background: var(--color-surface);
}

.hero-preview--background .hero-preview__shape--medium {
  background: var(--color-ivory);
}

.hero-preview__copy {
  display: flex;
  flex: 1 1 auto;
  flex-direction: column;
  gap: var(--space-2);
  min-width: 0;
}

.hero-preview__topline,
.option-card__topline,
.option-card__chips,
.option-card__footer {
  display: flex;
  align-items: center;
}

.hero-preview__topline,
.option-card__topline {
  justify-content: space-between;
  gap: var(--space-2);
}

.hero-preview__title {
  color: var(--color-ink);
  font-size: var(--font-size-section-title);
  font-weight: var(--font-weight-bold);
  line-height: var(--line-height-title);
}

.hero-preview__description {
  color: var(--color-ink-soft);
  font-size: var(--font-size-body);
  line-height: var(--line-height-body);
}

.hero-preview__state {
  align-self: flex-start;
  color: var(--color-primary-action);
  font-size: var(--font-size-caption);
  font-weight: var(--font-weight-semibold);
  line-height: 1.35;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.option-card {
  display: flex;
  gap: var(--space-3);
  min-height: 112px;
  padding: var(--space-4);
  background: var(--color-surface);
  border: var(--border-subtle);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-soft);
  transition: transform var(--motion-fast) var(--motion-ease),
    border-color var(--motion-fast) var(--motion-ease),
    background-color var(--motion-fast) var(--motion-ease);
}

.option-card--selected {
  background: var(--color-cream-pink-soft);
  border: var(--border-selected);
}

.option-card--previewing {
  border: var(--border-focus);
}

.option-card--disabled {
  background: var(--color-ivory);
  opacity: 0.78;
  pointer-events: none;
}

.option-card--success:active {
  transform: scale(0.99);
}

.option-card__preview {
  display: flex;
  flex: 0 0 58px;
  align-items: center;
  justify-content: center;
  height: 58px;
  background: var(--color-ivory);
  border: var(--border-subtle);
  border-radius: var(--radius-l);
}

.option-card__preview-mark {
  width: 28px;
  height: 28px;
  background: var(--color-cream-pink-soft);
  border: var(--border-subtle);
  border-radius: var(--radius-full);
}

.option-card__preview--full .option-card__preview-mark {
  width: 34px;
  border-radius: var(--radius-m);
}

.option-card__preview--subject .option-card__preview-mark {
  height: 36px;
  background: var(--color-cream-pink);
  border-radius: var(--radius-l);
}

.option-card__preview--background .option-card__preview-mark {
  background: var(--color-surface);
}

.option-card__body {
  display: flex;
  flex: 1 1 auto;
  flex-direction: column;
  gap: var(--space-2);
  min-width: 0;
}

.option-card__title {
  color: var(--color-ink);
  font-size: var(--font-size-card-title);
  font-weight: var(--font-weight-semibold);
  line-height: var(--line-height-title);
}

.option-card__chips {
  flex: 0 0 auto;
  gap: var(--space-1);
}

.option-chip {
  padding: var(--space-1) var(--space-2);
  color: var(--color-ink-soft);
  background: var(--color-ivory);
  border: var(--border-subtle);
  border-radius: var(--radius-full);
  font-size: var(--font-size-micro);
  font-weight: var(--font-weight-semibold);
  line-height: 1.2;
}

.option-chip--recommended {
  color: var(--color-ink);
  background: var(--color-oat-yellow-soft);
  border-color: var(--color-oat-yellow);
}

.option-chip--failed,
.option-chip--timeout {
  color: var(--color-error);
}

.option-chip--pending,
.option-chip--processing {
  color: var(--color-warning);
}

.option-card__description,
.option-card__state,
.option-card__error {
  font-size: var(--font-size-caption);
  line-height: 1.45;
}

.option-card__description {
  color: var(--color-ink-soft);
}

.option-card__state {
  color: var(--color-primary-action);
  font-weight: var(--font-weight-semibold);
}

.option-card__state--muted {
  color: var(--color-muted);
}

.option-card__error {
  color: var(--color-error);
}

.regeneration-dialog {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.regeneration-dialog__scrim {
  position: absolute;
  inset: 0;
  background: var(--color-ink);
  opacity: 0.18;
}

.regeneration-dialog__surface {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  width: calc(100% - var(--page-padding-x) * 2);
  margin: 0 var(--page-padding-x) calc(var(--space-4) + env(safe-area-inset-bottom));
  padding: var(--space-5);
  background: var(--color-surface);
  border: var(--border-subtle);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-elevated);
}

.regeneration-dialog__title {
  color: var(--color-ink);
  font-size: var(--font-size-section-title);
  font-weight: var(--font-weight-bold);
  line-height: var(--line-height-title);
}

.regeneration-dialog__copy,
.regeneration-dialog__hint {
  color: var(--color-ink-soft);
  font-size: var(--font-size-body);
  line-height: var(--line-height-body);
}

.regeneration-dialog__hint {
  color: var(--color-muted);
  font-size: var(--font-size-caption);
}

.regeneration-dialog__actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-3);
  margin-top: var(--space-2);
}
