<view class="generation-options-page">
  <top-navigation
    title="方案选择"
    backLabel="返回"
    bind:back="handleBack"
  />

  <view class="generation-options-page__content">
    <view class="generation-options-page__header">
      <text class="generation-options-page__title">选择一个生成方案</text>
      <text class="generation-options-page__subtitle">
        长按可临时预览，点击可选择可用方案。
      </text>
    </view>

    <base-card variant="floating">
      <view class="hero-preview hero-preview--{{heroOption.previewTone}}">
        <view class="hero-preview__visual" aria-hidden="true">
          <view class="hero-preview__canvas">
            <view class="hero-preview__shape hero-preview__shape--large"></view>
            <view class="hero-preview__shape hero-preview__shape--medium"></view>
            <view class="hero-preview__shape hero-preview__shape--small"></view>
          </view>
        </view>

        <view class="hero-preview__copy">
          <view class="hero-preview__topline">
            <text class="hero-preview__title">{{heroOption.label}}</text>
            <text
              wx:if="{{heroOption.recommended}}"
              class="option-chip option-chip--recommended"
            >
              推荐
            </text>
          </view>
          <text class="hero-preview__description">{{heroOption.description}}</text>
          <text class="hero-preview__state">
            {{isPreviewing ? '预览中' : selectedOptionType ? '已选择' : '待选择'}}
          </text>
        </view>
      </view>
    </base-card>

    <view class="option-list">
      <view
        wx:for="{{options}}"
        wx:key="type"
        class="option-card option-card--{{item.status}} {{item.type === selectedOptionType ? 'option-card--selected' : ''}} {{item.type === previewOptionType ? 'option-card--previewing' : ''}} {{!item.selectable ? 'option-card--disabled' : ''}}"
        data-type="{{item.type}}"
        bindtap="onOptionTap"
        bindlongpress="onOptionLongPress"
        bindtouchend="onOptionTouchEnd"
        bindtouchcancel="onOptionTouchCancel"
      >
        <view class="option-card__preview option-card__preview--{{item.previewTone}}">
          <view class="option-card__preview-mark"></view>
        </view>

        <view class="option-card__body">
          <view class="option-card__topline">
            <text class="option-card__title">{{item.label}}</text>
            <view class="option-card__chips">
              <text
                wx:if="{{item.recommended}}"
                class="option-chip option-chip--recommended"
              >
                推荐
              </text>
              <text class="option-chip option-chip--{{item.status}}">
                {{item.statusLabel}}
              </text>
            </view>
          </view>

          <text class="option-card__description">{{item.description}}</text>

          <view class="option-card__footer">
            <text
              wx:if="{{item.type === selectedOptionType && item.selectable}}"
              class="option-card__state"
            >
              已选择
            </text>
            <text
              wx:elif="{{item.type === previewOptionType}}"
              class="option-card__state"
            >
              预览中
            </text>
            <text wx:elif="{{!item.selectable}}" class="option-card__state">
              不可选择
            </text>
            <text wx:else class="option-card__state option-card__state--muted">
              点击选择
            </text>
          </view>

          <text wx:if="{{item.errorMessage}}" class="option-card__error">
            {{item.errorMessage}}
          </text>
        </view>
      </view>
    </view>
  </view>

  <bottom-action-bar>
    <base-button
      slot="secondary"
      variant="secondary"
      label="重新生成"
      bind:press="handleRegenerateTap"
    />
    <base-button
      block
      label="下一步"
      disabled="{{!canContinue}}"
      bind:press="handleNext"
    />
  </bottom-action-bar>

  <view wx:if="{{showRegenerationDialog}}" class="regeneration-dialog">
    <view class="regeneration-dialog__scrim" bindtap="handleRegenerationCancel"></view>
    <view class="regeneration-dialog__surface" role="dialog" aria-modal="true">
      <text class="regeneration-dialog__title">重新生成方案？</text>
      <text class="regeneration-dialog__copy">
        重新生成会使用 1 次每日重新生成机会。
      </text>
      <text class="regeneration-dialog__hint">
        UI 预览：今日剩余 {{regenerationRemainingPreviewCount}} 次。
      </text>
      <view class="regeneration-dialog__actions">
        <base-button
          variant="secondary"
          label="取消"
          bind:press="handleRegenerationCancel"
        />
        <base-button
          label="确认"
          bind:press="handleRegenerationConfirm"
        />
      </view>
    </view>
  </view>
</view>
