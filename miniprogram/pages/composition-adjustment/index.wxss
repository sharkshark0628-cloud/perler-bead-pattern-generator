.composition-adjustment-page {
  min-height: 100vh;
  background: var(--color-ivory);
}

.composition-adjustment-page__content {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  padding: var(--space-5) var(--page-padding-x) calc(var(--space-16) + var(--space-8));
}

.composition-adjustment-page__header {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.composition-adjustment-page__title {
  color: var(--color-ink);
  font-size: var(--font-size-page-title);
  font-weight: var(--font-weight-bold);
  line-height: var(--line-height-title);
}

.composition-adjustment-page__subtitle,
.composition-adjustment-page__note {
  color: var(--color-ink-soft);
  font-size: var(--font-size-body);
  line-height: var(--line-height-body);
}

.composition-adjustment-page__note {
  color: var(--color-muted);
  font-size: var(--font-size-caption);
}

.composition-preview {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.composition-preview__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-3);
}

.composition-preview__copy {
  display: flex;
  flex: 1 1 auto;
  flex-direction: column;
  gap: var(--space-1);
  min-width: 0;
}

.composition-preview__title {
  color: var(--color-ink);
  font-size: var(--font-size-section-title);
  font-weight: var(--font-weight-bold);
  line-height: var(--line-height-title);
}

.composition-preview__caption {
  color: var(--color-muted);
  font-size: var(--font-size-caption);
  line-height: 1.45;
}

.composition-preview__chip {
  flex: 0 0 auto;
  padding: var(--space-1) var(--space-3);
  color: var(--color-ink);
  background: var(--color-oat-yellow-soft);
  border: 1px solid var(--color-oat-yellow);
  border-radius: var(--radius-full);
  font-size: var(--font-size-micro);
  font-weight: var(--font-weight-semibold);
  line-height: 1.3;
}

.composition-board {
  padding: var(--space-3);
  background: var(--color-ivory);
  border: var(--border-standard);
  border-radius: var(--radius-l);
}

.composition-board__grid {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
  background: var(--color-surface);
  border: var(--border-subtle);
  border-radius: var(--radius-m);
}

.composition-board__grid::before {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(var(--color-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--color-line) 1px, transparent 1px);
  background-size: 10% 10%;
  content: "";
}

.composition-subject {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 48%;
  height: 48%;
  transform: translate(-50%, -50%);
  transition: top var(--motion-fast) var(--motion-ease),
    left var(--motion-fast) var(--motion-ease),
    width var(--motion-fast) var(--motion-ease),
    height var(--motion-fast) var(--motion-ease);
}

.composition-subject--x-left {
  left: 36%;
}

.composition-subject--x-right {
  left: 64%;
}

.composition-subject--y-top {
  top: 36%;
}

.composition-subject--y-bottom {
  top: 64%;
}

.composition-subject--scale-small {
  width: 38%;
  height: 38%;
}

.composition-subject--scale-large {
  width: 58%;
  height: 58%;
}

.composition-subject__shape {
  position: absolute;
  border: var(--border-subtle);
  border-radius: var(--radius-l);
}

.composition-subject__shape--large {
  right: 10%;
  bottom: 8%;
  width: 62%;
  height: 68%;
  background: var(--color-cream-pink-soft);
}

.composition-subject__shape--medium {
  top: 10%;
  left: 12%;
  width: 42%;
  height: 42%;
  background: var(--color-oat-yellow-soft);
  border-radius: var(--radius-full);
}

.composition-subject__shape--small {
  top: 18%;
  right: 16%;
  width: 22%;
  height: 22%;
  background: var(--color-surface);
  border-radius: var(--radius-full);
}

.composition-subject--subject .composition-subject__shape--large {
  right: 18%;
  bottom: 10%;
  width: 50%;
  background: var(--color-cream-pink);
}

.composition-subject--subject .composition-subject__shape--medium {
  left: 20%;
}

.composition-subject--background .composition-subject__shape--large {
  right: 20%;
  bottom: 14%;
  background: var(--color-surface);
}

.composition-subject--background .composition-subject__shape--medium {
  background: var(--color-ivory);
}

.adjustment-panel,
.adjustment-group {
  display: flex;
  flex-direction: column;
}

.adjustment-panel {
  gap: var(--space-5);
}

.adjustment-group {
  gap: var(--space-3);
}

.adjustment-group__label {
  color: var(--color-ink);
  font-size: var(--font-size-card-title);
  font-weight: var(--font-weight-semibold);
  line-height: var(--line-height-title);
}

.segmented-control {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-2);
}

.segmented-control__option {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 48px;
  padding: 0 var(--space-2);
  color: var(--color-ink-soft);
  background: var(--color-ivory);
  border: var(--border-subtle);
  border-radius: var(--radius-m);
  font-size: var(--font-size-body);
  font-weight: var(--font-weight-semibold);
  line-height: 1;
  transition: transform var(--motion-fast) var(--motion-ease),
    border-color var(--motion-fast) var(--motion-ease),
    background-color var(--motion-fast) var(--motion-ease);
}

.segmented-control__option:active {
  transform: scale(0.98);
}

.segmented-control__option--selected {
  color: var(--color-ink);
  background: var(--color-cream-pink-soft);
  border: var(--border-selected);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-5) 0;
  text-align: center;
}

.empty-state__mark {
  width: 64px;
  height: 64px;
  background: var(--color-cream-pink-soft);
  border: var(--border-subtle);
  border-radius: var(--radius-l);
}

.empty-state__title {
  color: var(--color-ink);
  font-size: var(--font-size-section-title);
  font-weight: var(--font-weight-bold);
  line-height: var(--line-height-title);
}

.empty-state__copy {
  max-width: 260px;
  color: var(--color-ink-soft);
  font-size: var(--font-size-body);
  line-height: var(--line-height-body);
}
