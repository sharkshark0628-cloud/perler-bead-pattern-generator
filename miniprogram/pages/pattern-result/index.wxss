.pattern-result-page {
  min-height: 100vh;
  background: var(--color-ivory);
}

.pattern-result-page__content {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  padding: var(--space-5) var(--page-padding-x) calc(var(--space-16) + var(--space-8));
}

.result-summary {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.result-summary__title {
  color: var(--color-ink);
  font-size: var(--font-size-page-title);
  font-weight: var(--font-weight-bold);
  line-height: var(--line-height-title);
}

.result-summary__subtitle {
  color: var(--color-ink-soft);
  font-size: var(--font-size-body);
  line-height: var(--line-height-body);
}

.pattern-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.pattern-card__header,
.preview-overlay__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-3);
}

.pattern-card__copy,
.preview-overlay__copy {
  display: flex;
  flex: 1 1 auto;
  flex-direction: column;
  gap: var(--space-1);
  min-width: 0;
}

.pattern-card__title,
.preview-overlay__title {
  color: var(--color-ink);
  font-size: var(--font-size-section-title);
  font-weight: var(--font-weight-bold);
  line-height: var(--line-height-title);
}

.pattern-card__caption,
.pattern-card__hint,
.preview-overlay__caption {
  color: var(--color-muted);
  font-size: var(--font-size-caption);
  line-height: 1.45;
}

.pattern-card__chip {
  flex: 0 0 auto;
  padding: var(--space-1) var(--space-3);
  color: var(--color-ink);
  background: var(--color-oat-yellow-soft);
  border: 1px solid var(--color-oat-yellow);
  border-radius: var(--radius-full);
  font-size: var(--font-size-micro);
  font-weight: var(--font-weight-semibold);
  line-height: 1.3;
}

.pattern-preview {
  display: flex;
  flex-direction: column;
  aspect-ratio: 1;
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
  background: var(--color-ivory);
  border: var(--border-standard);
  border-radius: var(--radius-l);
}

.pattern-preview--large {
  width: 100%;
  max-width: 72vh;
  margin: 0 auto;
}

.pattern-preview__row {
  display: flex;
  flex: 1 1 0;
  min-height: 0;
}

.pattern-preview__cell {
  display: flex;
  flex: 1 1 0;
  align-items: center;
  box-sizing: border-box;
  justify-content: center;
  min-width: 0;
  background: var(--color-surface);
  border-right: var(--border-subtle);
  border-bottom: var(--border-subtle);
}

.pattern-preview__cell--empty {
  background: var(--color-ivory);
}

.pattern-preview__cell--pink {
  background: var(--color-cream-pink);
}

.pattern-preview__cell--yellow {
  background: var(--color-oat-yellow);
}

.pattern-preview__cell--surface {
  background: var(--color-surface);
}

.pattern-preview__cell--soft {
  background: var(--color-cream-pink-soft);
}

.pattern-preview__cell--ink {
  background: var(--color-line-strong);
}

.pattern-preview__symbol {
  color: var(--color-ink);
  font-size: var(--font-size-micro);
  font-weight: var(--font-weight-semibold);
  line-height: 1;
}

.metadata-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-3);
}

.metadata-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-3);
}

.metadata-item__label {
  color: var(--color-muted);
  font-size: var(--font-size-caption);
  line-height: 1.45;
}

.metadata-item__value {
  color: var(--color-ink);
  font-size: var(--font-size-body);
  font-weight: var(--font-weight-semibold);
  line-height: var(--line-height-body);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-5) 0;
  text-align: center;
}

.empty-state__mark {
  width: 64px;
  height: 64px;
  background: var(--color-cream-pink-soft);
  border: var(--border-subtle);
  border-radius: var(--radius-l);
}

.empty-state__title {
  color: var(--color-ink);
  font-size: var(--font-size-section-title);
  font-weight: var(--font-weight-bold);
  line-height: var(--line-height-title);
}

.empty-state__copy {
  max-width: 260px;
  color: var(--color-ink-soft);
  font-size: var(--font-size-body);
  line-height: var(--line-height-body);
}

.preview-overlay {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.preview-overlay__scrim {
  position: absolute;
  inset: 0;
  background: var(--color-ink);
  opacity: 0.18;
}

.preview-overlay__surface {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  width: calc(100% - var(--page-padding-x) * 2);
  max-height: calc(100vh - var(--space-12));
  margin: 0 var(--page-padding-x) calc(var(--space-4) + env(safe-area-inset-bottom));
  padding: var(--space-5);
  overflow: auto;
  background: var(--color-surface);
  border: var(--border-subtle);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-elevated);
}
