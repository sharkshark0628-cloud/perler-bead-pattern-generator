.generation-settings-page {
  min-height: 100vh;
  padding-bottom: 104px;
  background: var(--color-ivory);
}

.generation-settings-page__content {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  padding: var(--space-4) var(--page-padding-x) var(--space-8);
}

.settings-section {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.settings-section__header {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.settings-section__title,
.ai-processing__title {
  color: var(--color-ink);
  font-size: var(--font-size-section-title);
  font-weight: var(--font-weight-semibold);
  line-height: var(--line-height-title);
}

.settings-section__caption,
.ai-processing__caption {
  color: var(--color-ink-soft);
  font-size: var(--font-size-caption);
  line-height: 1.45;
}

.settings-option-grid {
  display: grid;
  gap: var(--space-3);
}

.settings-option-grid--board,
.settings-option-grid--difficulty {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.settings-option,
.brand-option {
  display: flex;
  min-width: 0;
  min-height: 72px;
  padding: var(--space-3);
  background: var(--color-surface);
  border: var(--border-subtle);
  border-radius: var(--radius-m);
  transition:
    background var(--motion-fast) var(--motion-ease),
    border-color var(--motion-fast) var(--motion-ease),
    transform var(--motion-fast) var(--motion-ease);
}

.settings-option {
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: var(--space-2);
  text-align: center;
}

.settings-option--with-description {
  align-items: stretch;
  justify-content: flex-start;
  min-height: 122px;
  text-align: left;
}

.settings-option--selected,
.brand-option--selected {
  background: var(--color-cream-pink-soft);
  border: var(--border-selected);
}

.settings-option__topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-width: 0;
  gap: var(--space-2);
}

.settings-option__label,
.brand-option__name {
  color: var(--color-ink);
  font-size: var(--font-size-card-title);
  font-weight: var(--font-weight-semibold);
  line-height: var(--line-height-title);
}

.settings-option__description {
  color: var(--color-ink-soft);
  font-size: var(--font-size-caption);
  line-height: 1.4;
  overflow-wrap: anywhere;
}

.settings-option__state,
.brand-option__state {
  flex: 0 0 auto;
  color: var(--color-primary-action);
  font-size: var(--font-size-micro);
  font-weight: var(--font-weight-semibold);
  line-height: 1.2;
}

.brand-option {
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
}

.brand-option__copy {
  display: flex;
  flex-direction: column;
  min-width: 0;
  gap: var(--space-1);
}

.brand-option__caption {
  color: var(--color-muted);
  font-size: var(--font-size-caption);
  line-height: 1.4;
}

.ai-processing {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.ai-processing__header {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.ai-processing__list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-3);
}

.ai-processing__item {
  display: flex;
  align-items: center;
  min-width: 0;
  min-height: 44px;
  padding: var(--space-2) var(--space-3);
  background: var(--color-surface);
  border: var(--border-subtle);
  border-radius: var(--radius-m);
}

.ai-processing__mark {
  flex: 0 0 auto;
  width: 8px;
  height: 8px;
  margin-right: var(--space-2);
  background: var(--color-success);
  border-radius: var(--radius-full);
}

.ai-processing__label {
  color: var(--color-ink);
  font-size: var(--font-size-caption);
  line-height: 1.35;
}
