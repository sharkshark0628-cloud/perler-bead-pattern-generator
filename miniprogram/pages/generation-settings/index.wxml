<view class="generation-settings-page">
  <top-navigation
    title="生成设置"
    backLabel="返回"
    bind:back="handleBack"
  />

  <view class="generation-settings-page__content">
    <base-card>
      <view class="settings-section">
        <view class="settings-section__header">
          <text class="settings-section__title">豆板尺寸</text>
          <text class="settings-section__caption">选择这次图纸的成品大小</text>
        </view>

        <view class="settings-option-grid settings-option-grid--board">
          <view
            wx:for="{{boardSizeOptions}}"
            wx:key="value"
            class="settings-option {{item.value === selectedBoardSize ? 'settings-option--selected' : ''}}"
            data-value="{{item.value}}"
            bindtap="handleBoardSizeSelect"
          >
            <text class="settings-option__label">{{item.label}}</text>
            <text
              wx:if="{{item.value === selectedBoardSize}}"
              class="settings-option__state"
            >
              已选
            </text>
          </view>
        </view>
      </view>
    </base-card>

    <base-card>
      <view class="settings-section">
        <view class="settings-section__header">
          <text class="settings-section__title">制作难度</text>
          <text class="settings-section__caption">控制图纸细节与制作轻松度</text>
        </view>

        <view class="settings-option-grid settings-option-grid--difficulty">
          <view
            wx:for="{{difficultyOptions}}"
            wx:key="value"
            class="settings-option settings-option--with-description {{item.value === selectedDifficulty ? 'settings-option--selected' : ''}}"
            data-value="{{item.value}}"
            bindtap="handleDifficultySelect"
          >
            <view class="settings-option__topline">
              <text class="settings-option__label">{{item.label}}</text>
              <text
                wx:if="{{item.value === selectedDifficulty}}"
                class="settings-option__state"
              >
                已选
              </text>
            </view>
            <text class="settings-option__description">{{item.description}}</text>
          </view>
        </view>
      </view>
    </base-card>

    <base-card>
      <view class="settings-section">
        <view class="settings-section__header">
          <text class="settings-section__title">拼豆品牌</text>
          <text class="settings-section__caption">当前使用参考色板</text>
        </view>

        <view
          class="brand-option brand-option--selected"
          data-value="{{selectedBrand}}"
          bindtap="handleBrandTap"
        >
          <view class="brand-option__copy">
            <text class="brand-option__name">MARD</text>
            <text class="brand-option__caption">更多品牌即将支持</text>
          </view>
          <text class="brand-option__state">已选</text>
        </view>
      </view>
    </base-card>

    <base-card variant="tinted">
      <view class="ai-processing">
        <view class="ai-processing__header">
          <text class="ai-processing__title">AI 自动处理</text>
          <text class="ai-processing__caption">
            系统会自动处理这些步骤，你只需要确认基础设置。
          </text>
        </view>

        <view class="ai-processing__list">
          <view
            wx:for="{{aiProcessingItems}}"
            wx:key="label"
            class="ai-processing__item"
          >
            <view class="ai-processing__mark"></view>
            <text class="ai-processing__label">{{item.label}}</text>
          </view>
        </view>
      </view>
    </base-card>
  </view>

  <bottom-action-bar>
    <base-button
      block
      label="开始生成"
      bind:press="handleStart"
    />
  </bottom-action-bar>
</view>
