.flow-step-indicator {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  width: 100%;
  padding: 0 var(--page-padding-x);
  overflow: hidden;
}

.flow-step-indicator__item {
  display: flex;
  flex: 1;
  align-items: center;
  min-width: 0;
  color: var(--color-muted);
}

.flow-step-indicator__dot {
  flex: 0 0 auto;
  width: 8px;
  height: 8px;
  margin-right: var(--space-1);
  border: 1px solid var(--color-line-strong);
  border-radius: var(--radius-full);
  background: var(--color-surface);
}

.flow-step-indicator__label {
  overflow: hidden;
  font-size: var(--font-size-micro);
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.flow-step-indicator__item.is-current {
  color: var(--color-ink);
}

.flow-step-indicator__item.is-current .flow-step-indicator__dot {
  border-color: var(--color-primary-action);
  background: var(--color-primary-action);
}

.flow-step-indicator__item.is-complete .flow-step-indicator__dot {
  border-color: var(--color-cream-pink);
  background: var(--color-cream-pink-soft);
}

